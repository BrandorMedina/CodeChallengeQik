{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "setupFilesAfterEnv": [],
  "globalTeardown": "<rootDir>/teardown.ts",
  "detectOpenHandles": true,
  "forceExit": true,
  "verbose": true
}